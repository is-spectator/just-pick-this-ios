    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
