APP_NAME=just-pick-this-backend
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/just_pick_this

# Card composition. deterministic is offline and test-friendly.
# Set to deepseek to let Pipi adapt database references into card copy via AI.
PIPI_CARD_COMPOSER=deterministic
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT_SECONDS=20

# Optional web evidence and reference images. Disabled when the key is empty.
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=tvly-YOUR_API_KEY
TAVILY_SEARCH_MAX_RESULTS=5
TAVILY_IMAGE_MAX_RESULTS=8
TAVILY_TIMEOUT_SECONDS=8
