APP_NAME=just-pick-this-backend
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
PIPI_EVAL_MODE=false
API_V1_PREFIX=/v1
DATABASE_URL=postgresql+psycopg://just_pick_this:just_pick_this@localhost:5432/just_pick_this_agent_v0
AUTO_SEED_ON_REQUEST=false
REQUIRE_DEVICE_UID=true
ENABLE_ADMIN_ROUTES=true
ENABLE_DEBUG_ROUTES=false
ALLOW_EVAL_BYPASS=false

# V0 production strategy: strong LangGraph checkpointing is not enabled.
# Keep required=false; readiness reports checkpoint=not_required.
LANGGRAPH_CHECKPOINT_REQUIRED=false
LANGGRAPH_CHECKPOINT_BACKEND=disabled

# Pipi model routing and card composition.
# Product runtime stays deterministic; LLM shadow mode is opt-in below.
PIPI_MODEL_PROVIDER=deterministic
PIPI_CARD_COMPOSER=deterministic
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
# To route product /v1/chat/turn through OpenAI:
# PIPI_MODEL_PROVIDER=openai
LLM_SHADOW_ENABLED=false
LLM_PROVIDER=none
LLM_MODEL=none
LLM_TIMEOUT_SECONDS=10
LLM_REWRITE_ENABLED=false
LLM_REWRITE_MIN_CONFIDENCE=0.78
# To audit real LLM decisions without changing product output:
# LLM_SHADOW_ENABLED=true
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4.1-mini
# To audit LLM query rewrite without changing tool execution:
# LLM_REWRITE_ENABLED=true
# LLM_PROVIDER=mock_shadow

# Optional web evidence and reference images. Disabled when the key is empty.
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=tvly-YOUR_API_KEY
TAVILY_SEARCH_MAX_RESULTS=5
TAVILY_IMAGE_MAX_RESULTS=8
TAVILY_TIMEOUT_SECONDS=8

# Optional AMap Web Service integration for POI search and route cards.
# The key stays on the backend; it is never sent to iOS clients.
AMAP_WEB_SERVICE_KEY=
AMAP_SEARCH_RADIUS_METERS=1200
AMAP_SEARCH_LIMIT=20
AMAP_ROUTE_MODE_DEFAULT=walking

# Required for /admin.
ADMIN_TOKEN=

# Email verification login. Local tests can keep EMAIL_PROVIDER=console.
# Production/staging must use smtp and set JWT_SECRET + SMTP credentials.
JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=86400
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_PROVIDER=console
EMAIL_FROM_NAME=皮皮
EMAIL_FROM_ADDRESS=
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=15

# Alibaba Cloud Enterprise Email example:
# SMTP_HOST=smtp.qiye.aliyun.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USE_STARTTLS=false

# Optional. When debug routes are mounted, /debug/sessions and /debug/api/*
# require Authorization: Bearer <DEBUG_DASHBOARD_TOKEN>.
DEBUG_DASHBOARD_TOKEN=
